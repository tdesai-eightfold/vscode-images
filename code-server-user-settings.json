{
  "chat.disableAIFeatures": true,
  "terminal.integrated.profiles.linux": {
    "Candidate (workspace)": {
      "path": "/bin/bash",
      "args": ["-l", "-i"],
      "cwd": "${workspaceFolder}",
      "env": {
        "HOME": "/home/candidate",
        "PATH": "/home/candidate/.local/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  },
  "terminal.integrated.defaultProfile.linux": "Candidate (workspace)",
  "workbench.activityBar.location": "hidden",
  "workbench.statusBar.visible": false,
  "editor.lineNumbers": "on"
}
